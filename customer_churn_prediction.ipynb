   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "from sklearn.model_selection import train_test_split,cross_val_score\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.metrics import classification_report,confusion_matrix,accuracy_score\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "a3bb4c5c",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv(r"customer_churn.csv")
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "bec1113f",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[\"TotalCharges\"]= pd.to_numeric(df[\"TotalCharges\"],errors= \"coerce\")\n",
    "df = df.dropna()\n",
    "df = pd.get_dummies(df,drop_first=True)\n",
    "df = df.drop(columns=[\"customerID\"],errors = \"ignore\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "7b00231a",
   "metadata": {},
   "outputs": [],
   "source": [
    "x = df.drop(\"Churn_Yes\",axis = 1)\n",
    "y= df[\"Churn_Yes\"]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "b76edd0d",
   "metadata": {},
   "outputs": [],
   "source": [
    "x_train,x_test,y_train,y_test = train_test_split(x,y,test_size=0.2,random_state=42,shuffle = True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "b04e7175",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Classification Report               precision    recall  f1-score   support\n",
      "\n",
      "       False       0.91      0.67      0.77      1033\n",
      "        True       0.47      0.81      0.59       374\n",
      "\n",
      "    accuracy                           0.70      1407\n",
      "   macro avg       0.69      0.74      0.68      1407\n",
      "weighted avg       0.79      0.70      0.72      1407\n",
      "\n",
      "Confusion Matrix [[689 344]\n",
      " [ 72 302]]\n",
      "Accuracy  0.7043354655294953\n",
      "Recall scores  [0.87433155 0.8368984  0.81769437 0.8315508  0.8315508 ]\n",
      "mean 0.8384051841550658\n",
      "std 0.01905716223135893\n"
     ]
    }
   ],
   "source": [
    "#Random forest classifier\n",
    "r_model = RandomForestClassifier(max_depth=8,n_estimators=300,min_samples_leaf=5,class_weight='balanced',n_jobs = -1)\n",
    "r_model.fit(x_train,y_train)\n",
    "y_pred=r_model.predict(x_test)\n",
    "print(\"Classification Report\",classification_report(y_test,y_pred))\n",
    "print(\"Confusion Matrix\",confusion_matrix(y_test,y_pred))\n",
    "print(\"Accuracy \",accuracy_score(y_test,y_pred))\n",
    "recall_scores = cross_val_score(r_model,x,y,cv=5,scoring=\"recall\")\n",
    "print(\"Recall scores \",recall_scores)\n",
    "print(\"mean\",np.mean(recall_scores))\n",
    "print(\"std\",np.std(recall_scores))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "c67d9688",
   "metadata": {},
   "outputs": [
    {
     "data": {
